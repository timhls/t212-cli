# KeePass database path (override via $KDBX, defaults to user's standard location).
KDBX="${KDBX:-$HOME/KeePassXC/keepass.kdbx}"

# Trigger a macOS GUI prompt to ask for the database password
DB_PASS=$(osascript -e 'Tell application "System Events" to display dialog "Enter KeePassXC Password:" default answer "" with hidden answer' -e 'text returned of result')

export T212_API_KEY_ID=$(echo "$DB_PASS" | keepassxc-cli show -q -s -a username "$KDBX" "t212-cli")
export T212_SECRET_KEY=$(echo "$DB_PASS" | keepassxc-cli show -q -s -a password "$KDBX" "t212-cli")

export T212_BASE_URL="https://live.trading212.com/api/v0"

# Clean up the master password variable for security
unset DB_PASS
